{
  "headers": [
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|gif|webp|woff|woff2)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://your-django-backend.railway.app/api/v1/:path*"
    }
  ]
}
